# Base URL of the Skyderby Rails API (server-side fetches)
API_BASE_URL=http://localhost:3000
# Base URL exposed to the browser (client-side fetches and ActionCable)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Google Maps JS API key (optional; map renders a placeholder without it)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# OAuth (Doorkeeper) — register an application in the Rails app and fill these in.
# Auth routes return 503 until OAUTH_CLIENT_ID is set.
OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
OAUTH_SCOPE=read
